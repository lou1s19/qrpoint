{
  "expo": {
    "name": "qr-point-app",
    "slug": "qr-point-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "qrpointapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "QR Point benötigt die Kamera zum Scannen von QR-Codes.",
        "NSPhotoLibraryUsageDescription": "QR Point benötigt Zugriff auf Fotos für das Logo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        { "cameraPermission": "QR Point benötigt die Kamera zum Scannen von QR-Codes." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "QR Point benötigt Zugriff auf Fotos für das Logo." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
